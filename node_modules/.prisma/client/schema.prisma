// ===============================================================
// Overfloow Hub — Prisma Schema v1
// Prisma v5 + PostgreSQL + driver adapter
// schema: overfloow | Março/2026
// ===============================================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters", "multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["overfloow"]
}

// -- Usuários internos da equipe Overfloow ----------------------
model Usuario {
  id_usuario    Int             @id @default(autoincrement())
  nome          String          @db.VarChar(200)
  email         String          @unique @db.VarChar(200)
  celular       String?         @db.VarChar(50)
  whatsapp      String?         @db.VarChar(50)
  senha_hash    String
  ativo         Boolean         @default(true)
  criado_em     DateTime        @default(now()) @db.Timestamp(6)
  atualizado_em DateTime        @default(now()) @updatedAt @db.Timestamp(6)
  perfis        UsuarioPerfil[]

  @@map("usuarios")
  @@schema("overfloow")
}

// -- Perfis de acesso (roles) -----------------------------------
model Perfil {
  id_perfil Int             @id @default(autoincrement())
  nome      String          @unique @db.VarChar(100)
  descricao String?
  ativo     Boolean         @default(true)
  criado_em DateTime        @default(now()) @db.Timestamp(6)
  usuarios  UsuarioPerfil[]

  @@map("perfis")
  @@schema("overfloow")
}

// -- Relação usuário <-> perfil (N:N) ---------------------------
model UsuarioPerfil {
  id_usuario Int
  id_perfil  Int
  criado_em  DateTime @default(now()) @db.Timestamp(6)
  usuario    Usuario  @relation(fields: [id_usuario], references: [id_usuario], onDelete: Cascade)
  perfil     Perfil   @relation(fields: [id_perfil], references: [id_perfil], onDelete: Cascade)

  @@id([id_usuario, id_perfil])
  @@map("usuarios_perfis")
  @@schema("overfloow")
}

// -- Clientes contratantes --------------------------------------
model Cliente {
  id_cliente    Int      @id @default(autoincrement())
  nome          String   @db.VarChar(200)
  razao_social  String?  @db.VarChar(200)
  cnpj          String?  @db.VarChar(20)
  email         String?  @db.VarChar(200)
  telefone      String?  @db.VarChar(50)
  endereco      String?
  cidade        String?  @db.VarChar(100)
  estado        String?  @db.VarChar(2)
  cep           String?  @db.VarChar(10)
  pais          String   @default("Brasil") @db.VarChar(100)
  segmento      String?  @db.VarChar(100)
  porte         String?  @db.VarChar(50)
  status        String   @default("ativo") @db.VarChar(50)
  id_schema     String?  @unique @db.VarChar(100)
  ativo         Boolean  @default(true)
  criado_em     DateTime @default(now()) @db.Timestamp(6)
  atualizado_em DateTime @default(now()) @updatedAt @db.Timestamp(6)

  custos CustoCliente[]

  @@map("clientes")
  @@schema("overfloow")
}

// -- Custos/Despesas de Clientes --------------------------------
model CustoCliente {
  id_custo      Int      @id @default(autoincrement())
  id_cliente    Int
  descricao     String   @db.VarChar(300)
  categoria     String   @db.VarChar(100)
  valor         Decimal  @db.Decimal(10, 2)
  data_custo    DateTime @db.Date
  status        String   @default("Pendente") @db.VarChar(50)
  comprovante   String?  @db.Text
  observacoes   String?  @db.Text
  criado_em     DateTime @default(now()) @db.Timestamp(6)
  atualizado_em DateTime @default(now()) @updatedAt @db.Timestamp(6)

  cliente Cliente @relation(fields: [id_cliente], references: [id_cliente], onDelete: Cascade)

  @@map("custos_clientes")
  @@schema("overfloow")
}
