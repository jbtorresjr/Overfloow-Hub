// ===============================================================
// Overfloow Hub — Prisma Schema v1
// Prisma v5 + PostgreSQL + driver adapter
// schema: overfloow | Março/2026
// ===============================================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters", "multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["overfloow"]
}

// -- Usuários internos da equipe Overfloow ----------------------
model Usuario {
  id_usuario       Int                    @id @default(autoincrement())
  nome             String                 @db.VarChar(200)
  email            String                 @unique @db.VarChar(200)
  celular          String?                @db.VarChar(50)
  whatsapp         String?                @db.VarChar(50)
  senha_hash       String
  ativo            Boolean                @default(true)
  criado_em        DateTime               @default(now()) @db.Timestamp(6)
  atualizado_em    DateTime               @default(now()) @updatedAt @db.Timestamp(6)
  perfis           UsuarioPerfil[]
  pontos           PontoRegistro[]
  apontamentos     Apontamento[]
  reembolsos       ReembolsoSolicitacao[]
  config           ColaboradorConfig?
  reunioes_criadas Reuniao[]              @relation("ReunioesCriadas")

  @@map("usuarios")
  @@schema("overfloow")
}

// -- Perfis de acesso (roles) -----------------------------------
model Perfil {
  id_perfil Int             @id @default(autoincrement())
  nome      String          @unique @db.VarChar(100)
  descricao String?
  ativo     Boolean         @default(true)
  criado_em DateTime        @default(now()) @db.Timestamp(6)
  usuarios  UsuarioPerfil[]

  @@map("perfis")
  @@schema("overfloow")
}

// -- Relação usuário <-> perfil (N:N) ---------------------------
model UsuarioPerfil {
  id_usuario Int
  id_perfil  Int
  criado_em  DateTime @default(now()) @db.Timestamp(6)
  usuario    Usuario  @relation(fields: [id_usuario], references: [id_usuario], onDelete: Cascade)
  perfil     Perfil   @relation(fields: [id_perfil], references: [id_perfil], onDelete: Cascade)

  @@id([id_usuario, id_perfil])
  @@map("usuarios_perfis")
  @@schema("overfloow")
}

// -- Clientes contratantes --------------------------------------
model Cliente {
  id_cliente    Int      @id @default(autoincrement())
  nome          String   @db.VarChar(200)
  razao_social  String?  @db.VarChar(200)
  cnpj          String?  @db.VarChar(20)
  email         String?  @db.VarChar(200)
  telefone      String?  @db.VarChar(50)
  endereco      String?
  cidade        String?  @db.VarChar(100)
  estado        String?  @db.VarChar(2)
  cep           String?  @db.VarChar(10)
  pais          String   @default("Brasil") @db.VarChar(100)
  segmento      String?  @db.VarChar(100)
  porte         String?  @db.VarChar(50)
  status        String   @default("ativo") @db.VarChar(50)
  id_schema     String?  @unique @db.VarChar(100)
  ativo         Boolean  @default(true)
  criado_em     DateTime @default(now()) @db.Timestamp(6)
  atualizado_em DateTime @default(now()) @updatedAt @db.Timestamp(6)

  custos       CustoCliente[]
  apontamentos Apontamento[]
  projetos     Projeto[]
  reembolsos   ReembolsoSolicitacao[]
  reunioes     Reuniao[]

  @@map("clientes")
  @@schema("overfloow")
}

// -- Custos/Despesas de Clientes --------------------------------
model CustoCliente {
  id_custo      Int      @id @default(autoincrement())
  id_cliente    Int
  id_projeto    Int?     // FK opcional para projetos
  descricao     String   @db.VarChar(300)
  categoria     String   @db.VarChar(100)
  valor         Decimal  @db.Decimal(10, 2)
  data_custo    DateTime @db.Date
  status        String   @default("Pendente") @db.VarChar(50)
  comprovante   String?  @db.Text
  observacoes   String?  @db.Text
  criado_em     DateTime @default(now()) @db.Timestamp(6)
  atualizado_em DateTime @default(now()) @updatedAt @db.Timestamp(6)

  cliente  Cliente  @relation(fields: [id_cliente], references: [id_cliente], onDelete: Cascade)
  projeto  Projeto? @relation("CustosCliente", fields: [id_projeto], references: [id_projeto], onDelete: SetNull)

  @@map("custos_clientes")
  @@schema("overfloow")
}

// -- Controle de Ponto (Batidas do Relógio) ---------------------
model PontoRegistro {
  id_registro Int      @id @default(autoincrement())
  id_usuario  Int
  tipo        String   @db.VarChar(50) // ENTRADA, SAIDA_ALMOCO, RETORNO_ALMOCO, SAIDA
  hora        DateTime @db.Timestamp(6)
  local       String   @default("HOME_OFFICE") @db.VarChar(50) // HOME_OFFICE, CLIENTE, ESCRITORIO
  criado_em   DateTime @default(now()) @db.Timestamp(6)

  usuario Usuario @relation(fields: [id_usuario], references: [id_usuario], onDelete: Cascade)

  @@map("ponto_registros")
  @@schema("overfloow")
}

// -- Apontamentos de Atividades (Timesheet) ---------------------
model Apontamento {
  id_apontamento Int      @id @default(autoincrement())
  id_usuario     Int
  id_cliente     Int
  id_projeto     Int?
  inicio         String   @db.VarChar(5) // "08:00"
  fim            String   @db.VarChar(5) // "12:00"
  total_minutos  Int
  descricao      String   @db.Text
  tipo           String   @db.VarChar(50) // NORMAL, HE, BH_CREDITO
  data_ref       DateTime @db.Date
  criado_em      DateTime @default(now()) @db.Timestamp(6)

  usuario  Usuario  @relation(fields: [id_usuario], references: [id_usuario], onDelete: Cascade)
  cliente  Cliente  @relation(fields: [id_cliente], references: [id_cliente], onDelete: Cascade)
  projeto  Projeto? @relation(fields: [id_projeto], references: [id_projeto], onDelete: SetNull)

  @@map("apontamentos")
  @@schema("overfloow")
}

// -- Projetos ---------------------------------------------------
model Projeto {
  id_projeto    Int      @id @default(autoincrement())
  id_cliente    Int
  nome          String   @db.VarChar(200)
  status        String   @default("ATIVO") @db.VarChar(50)
  permite_he    Boolean  @default(false)
  permite_bh    Boolean  @default(false)
  cor           String   @default("#3A7BD5") @db.VarChar(20)
  criado_em     DateTime @default(now()) @db.Timestamp(6)
  atualizado_em DateTime @default(now()) @updatedAt @db.Timestamp(6)

  cliente       Cliente              @relation(fields: [id_cliente], references: [id_cliente], onDelete: Cascade)
  apontamentos  Apontamento[]
  reembolsos    ReembolsoSolicitacao[]
  reunioes      Reuniao[]
  custos        CustoCliente[]       @relation("CustosCliente")

  @@map("projetos")
  @@schema("overfloow")
}

// -- Reembolsos (Cabeçalho e Itens) -----------------------------
model ReembolsoSolicitacao {
  id_solicitacao Int     @id @default(autoincrement())
  id_usuario     Int
  id_cliente     Int
  id_projeto     Int?
  periodo_ref    String  @db.VarChar(50)
  observacao     String? @db.Text
  status         String  @default("PENDENTE") @db.VarChar(50)
  valor_total    Decimal @default(0.00) @db.Decimal(10, 2)

  chave_pix  String? @db.VarChar(200)
  tipo_pix   String? @db.VarChar(50)
  banco      String? @db.VarChar(100)
  agencia    String? @db.VarChar(20)
  conta      String? @db.VarChar(20)
  tipo_conta String? @db.VarChar(50)

  criado_em     DateTime @default(now()) @db.Timestamp(6)
  atualizado_em DateTime @default(now()) @updatedAt @db.Timestamp(6)

  usuario  Usuario              @relation(fields: [id_usuario], references: [id_usuario], onDelete: Cascade)
  cliente  Cliente              @relation(fields: [id_cliente], references: [id_cliente], onDelete: Cascade)
  projeto  Projeto?             @relation(fields: [id_projeto], references: [id_projeto], onDelete: SetNull)
  itens    ReembolsoItem[]

  @@map("reembolso_solicitacoes")
  @@schema("overfloow")
}

model ReembolsoItem {
  id_item        Int     @id @default(autoincrement())
  id_solicitacao Int
  doc_fiscal     String  @db.VarChar(100)
  fornecedor     String  @db.VarChar(200)
  forma_pgto     String  @db.VarChar(100)
  valor          Decimal @db.Decimal(10, 2)
  arquivo_url    String? @db.Text

  solicitacao ReembolsoSolicitacao @relation(fields: [id_solicitacao], references: [id_solicitacao], onDelete: Cascade)

  @@map("reembolso_itens")
  @@schema("overfloow")
}

// -- Configurações e Jornada de Trabalho (RH) -------------------
model ColaboradorConfig {
  id_config    Int    @id @default(autoincrement())
  id_usuario   Int    @unique
  cargo        String @db.VarChar(100)
  tipo_vinculo String @default("CLT") @db.VarChar(50)
  jornada      String @default("CLT_40") @db.VarChar(50)
  horas_mes    Int    @default(200)
  saldo_bh_min Int    @default(0)
  cor_badge    String @default("#4B5563") @db.VarChar(20)

  usuario Usuario @relation(fields: [id_usuario], references: [id_usuario], onDelete: Cascade)

  @@map("colaboradores_config")
  @@schema("overfloow")
}

// -- Reuniões e Pautas ------------------------------------------
model Reuniao {
  id_reuniao Int      @id @default(autoincrement())
  titulo     String   @db.VarChar(200)
  data_hora  DateTime @db.Timestamp(6)
  duracao_m  Int      @default(60)
  status     String   @default("AGENDADA") @db.VarChar(50)
  link_meet  String?  @db.Text
  pauta      String?  @db.Text
  ata        String?  @db.Text
  id_cliente Int?
  id_projeto Int?     // FK opcional para projetos
  criador_id Int
  criado_em  DateTime @default(now()) @db.Timestamp(6)

  cliente Cliente? @relation(fields: [id_cliente], references: [id_cliente], onDelete: SetNull)
  projeto Projeto? @relation(fields: [id_projeto], references: [id_projeto], onDelete: SetNull)
  criador Usuario  @relation("ReunioesCriadas", fields: [criador_id], references: [id_usuario], onDelete: Cascade)

  @@map("reunioes")
  @@schema("overfloow")
}

model AreasInternas {
  id_area_interna Int      @id @default(autoincrement())
  nome            String
  descricao       String?
  ativo           Boolean  @default(true)
  criado_em       DateTime @default(now())

  @@map("areas_internas")
  @@schema("overfloow")
}

model Pessoas {
  id_pessoa  Int      @id @default(autoincrement())
  id_usuario Int?
  nome       String
  cargo      String?
  email      String?
  celular    String?
  whatsapp   String?
  telegram   String?
  ativo      Boolean  @default(true)
  criado_em  DateTime @default(now())

  @@map("pessoas")
  @@schema("overfloow")
}

model AreaResponsaveis {
  id_area_responsavel Int      @id @default(autoincrement())
  id_area_interna     Int
  id_pessoa           Int
  tipo_responsavel    String   @default("principal")
  ativo               Boolean  @default(true)
  criado_em           DateTime @default(now())

  @@map("area_responsaveis")
  @@schema("overfloow")
}

model Agentes {
  id_agente                Int      @id @default(autoincrement())
  nome                     String
  descricao                String?
  categoria                String?
  tipo_agente              String   @default("externo")
  escopo                   String   @default("cliente")
  id_area_interna          Int?
  id_usuario_responsavel   Int?
  id_usuario_escalonamento Int?
  ativo                    Boolean  @default(true)
  versao                   Int      @default(1)
  criado_em                DateTime @default(now())
  atualizado_em            DateTime @default(now())

  @@map("agentes")
  @@schema("overfloow")
}

model Competencias {
  id_competencia Int     @id @default(autoincrement())
  dimensao       String
  nome           String
  descricao      String?
  nivel_min      Int     @default(0)
  nivel_max      Int     @default(5)

  @@map("competencias")
  @@schema("overfloow")
}

model AgentesCompetencias {
  id_agente_competencia Int     @id @default(autoincrement())
  id_agente             Int
  id_competencia        Int
  nivel_minimo          Int     @default(1)
  nivel_maximo          Int     @default(5)
  obrigatoria           Boolean @default(true)

  @@map("agentes_competencias")
  @@schema("overfloow")
}

model MaturidadeNiveis {
  id_maturidade       Int     @id @default(autoincrement())
  nivel               Int
  nivel_nome          String
  dimensao            String
  descricao           String?
  autonomia_permitida Int?
  risco_permitido     Int?
  profundidade_cham   Int?

  @@map("maturidade_niveis")
  @@schema("overfloow")
}

model AgentesMaturidade {
  id_agente_maturidade Int      @id @default(autoincrement())
  id_agente            Int
  id_maturidade_atual  Int
  id_maturidade_maxima Int
  avaliado_em          DateTime @default(now())

  @@map("agentes_maturidade")
  @@schema("overfloow")
}

model Politicas {
  id_politica Int      @id @default(autoincrement())
  area        String?
  nome        String
  descricao   String
  tipo        String
  ativo       Boolean  @default(true)
  versao      Int      @default(1)
  criado_em   DateTime @default(now())

  @@map("politicas")
  @@schema("overfloow")
}

model AgentesPoliticas {
  id_agente_politica Int      @id @default(autoincrement())
  id_agente          Int
  id_politica        Int
  obrigatoria        Boolean  @default(true)
  criado_em          DateTime @default(now())

  @@map("agentes_politicas")
  @@schema("overfloow")
}

model ClientesAreas {
  id_area    Int      @id @default(autoincrement())
  id_cliente Int
  codigo     String?
  nome       String
  descricao  String?
  ativo      Boolean  @default(true)
  criado_em  DateTime @default(now())

  @@map("clientes_areas")
  @@schema("overfloow")
}

model ClientesPessoas {
  id_pessoa  Int      @id @default(autoincrement())
  id_cliente Int
  nome       String
  cargo      String?
  email      String?
  celular    String?
  whatsapp   String?
  telegram   String?
  ativo      Boolean  @default(true)
  criado_em  DateTime @default(now())

  @@map("clientes_pessoas")
  @@schema("overfloow")
}

model ClientesAreasResponsaveis {
  id_area_responsavel Int      @id @default(autoincrement())
  id_cliente          Int
  id_area             Int
  id_pessoa           Int
  tipo_responsavel    String   @default("principal")
  ativo               Boolean  @default(true)
  criado_em           DateTime @default(now())

  @@map("clientes_areas_responsaveis")
  @@schema("overfloow")
}

model Processos {
  id_processo Int      @id @default(autoincrement())
  codigo      String   @unique
  nome        String
  descricao   String?
  area_codigo String?
  nivel_cham  String?
  ativo       Boolean  @default(true)
  criado_em   DateTime @default(now())

  @@map("processos")
  @@schema("overfloow")
}

model Funis {
  id_funil    Int      @id @default(autoincrement())
  id_processo Int
  nome        String
  descricao   String?
  versao      Int      @default(1)
  ativo       Boolean  @default(true)
  criado_em   DateTime @default(now())

  @@map("funis")
  @@schema("overfloow")
}

model FunilFases {
  id_fase          Int      @id @default(autoincrement())
  id_funil         Int
  ordem            Int
  nome             String
  descricao        String?
  criterio_entrada String?
  criterio_saida   String?
  tipo             String   @default("automatica")
  sla_horas        Int?
  criado_em        DateTime @default(now())

  @@map("funil_fases")
  @@schema("overfloow")
}

model FunilFaseAgentes {
  id_fase_agente Int      @id @default(autoincrement())
  id_fase        Int
  id_agente      Int
  papel          String   @default("executor")
