  @@map("funil_fase_agentes")
  @@schema("overfloow")
}

model ClientesProcessos {
  id_cliente_processo Int       @id @default(autoincrement())
  id_cliente          Int
  id_processo         Int
  id_area             Int?
  id_funil            Int?
  status              String    @default("ativo")
  ativado_em          DateTime  @default(now())
  encerrado_em        DateTime?
  configuracao        Json?     @default("{}")

  @@map("clientes_processos")
  @@schema("overfloow")
}

model Planos {
  id_plano      Int      @id @default(autoincrement())
  nome          String   @unique
  descricao     String?
  preco_mensal  Decimal?
  preco_anual   Decimal?
  max_agentes   Int?
  max_processos Int?
  max_canais    Int?
  trial_dias    Int      @default(7)
  ativo         Boolean  @default(true)
  criado_em     DateTime @default(now())

  @@map("planos")
  @@schema("overfloow")
}

model PlanosItens {
  id_plano_item Int     @id @default(autoincrement())
  id_plano      Int
  descricao     String
  incluido      Boolean @default(true)

  @@map("planos_itens")
  @@schema("overfloow")
}

model Contratacoes {
  id_contratacao Int       @id @default(autoincrement())
  id_cliente     Int
  id_plano       Int
  status         String    @default("ativo")
  data_inicio    DateTime  @default(now())
  data_fim       DateTime?
  valor_mensal   Decimal?
  forma_pgto     String?
  auto_renovar   Boolean   @default(true)
  criado_em      DateTime  @default(now())

  @@map("contratacoes")
  @@schema("overfloow")
}

model AtivacoesAiah {
  id_ativacao     Int       @id @default(autoincrement())
  id_contratacao  Int
  id_cliente      Int
  id_agente       Int
  id_processo     Int?
  id_area_cliente Int?
  nome_aiah       String?
  status          String    @default("pendente")
  schema_cliente  String?
  ativado_em      DateTime?
  encerrado_em    DateTime?
  criado_em       DateTime  @default(now())
  atualizado_em   DateTime  @default(now())

  @@map("ativacoes_aiah")
  @@schema("overfloow")
}

model AtivacaoStatusLog {
  id_log          Int      @id @default(autoincrement())
  id_ativacao     Int
  status_anterior String?
  status_novo     String
  motivo          String?
  id_usuario      Int?
  criado_em       DateTime @default(now())

  @@map("ativacao_status_log")
  @@schema("overfloow")
}

model Canais {
  id_canal  Int     @id @default(autoincrement())
  nome      String  @unique
  descricao String?
  icone     String?
  ativo     Boolean @default(true)

  @@map("canais")
  @@schema("overfloow")
}

model ClientesCanais {
  id_cliente_canal Int       @id @default(autoincrement())
  id_ativacao      Int
  id_canal         Int
  numero_telefone  String?
  token_api        String?
  webhook_url      String?
  identificador    String?
  status           String    @default("pendente")
  configuracao     Json?     @default("{}")
