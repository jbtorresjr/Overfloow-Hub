  @@schema("overfloow")
}

model ClientesPromptCustom {
  id_prompt_custom Int      @id @default(autoincrement())
  id_ativacao      Int
  nome_aiah        String?
  tom_voz          String?
  apresentacao     String?
  restricoes_extra String?
  idioma           String   @default("pt-BR")
  criado_em        DateTime @default(now())
  atualizado_em    DateTime @default(now())

  @@map("clientes_prompt_custom")
  @@schema("overfloow")
}

model AiahSessoes {
  id_sessao             Int       @id @default(autoincrement())
  id_ativacao           Int
  id_canal              Int?
  identificador_usuario String?
  nome_usuario          String?
  status                String    @default("ativa")
  iniciada_em           DateTime  @default(now())
  encerrada_em          DateTime?
  total_mensagens       Int       @default(0)
  escalada              Boolean   @default(false)

  @@map("aiah_sessoes")
  @@schema("overfloow")
}

model AiahMensagens {
  id_mensagem Int      @id @default(autoincrement())
  id_sessao   Int
  origem      String
  conteudo    String
  tokens      Int?
  latencia_ms Int?
  criado_em   DateTime @default(now())

  @@map("aiah_mensagens")
  @@schema("overfloow")
}

model AiahEscalamentos {
  id_escalamento    Int       @id @default(autoincrement())
  id_sessao         Int
  motivo            String
  nivel             Int       @default(1)
  id_pessoa_destino Int?
  status            String    @default("aberto")
  criado_em         DateTime  @default(now())
  resolvido_em      DateTime?

  @@map("aiah_escalamentos")
  @@schema("overfloow")
}

model AiahKpis {
  id_kpi                  Int      @id @default(autoincrement())
  id_ativacao             Int
  periodo                 DateTime
  total_sessoes           Int      @default(0)
  total_mensagens         Int      @default(0)
  total_escalamentos      Int      @default(0)
  taxa_resolucao          Decimal?
  tempo_resposta_medio_ms Int?
  satisfacao_media        Decimal?
  tokens_consumidos       Int?
  custo_estimado          Decimal?
  criado_em               DateTime @default(now())

  @@map("aiah_kpis")
  @@schema("overfloow")
}

model CrmEmpresas {
  id_empresa     Int      @id @default(autoincrement())
  nome           String
  razao_social   String?
  cnpj           String?
  segmento       String?
  porte          String?
  cidade         String?
  estado         String?
  pais           String   @default("Brasil")
  website        String?
  linkedin       String?
  id_cliente     Int?
  status         String   @default("prospect")
  id_responsavel Int?
  id_campanha    Int?
  id_canal_mkt   Int?
  id_midia       Int?
  criado_em      DateTime @default(now())
  atualizado_em  DateTime @default(now())

  @@map("crm_empresas")
  @@schema("overfloow")
}

model CrmContatos {
  id_contato Int      @id @default(autoincrement())
  id_empresa Int
  nome       String
  cargo      String?
  email      String?
  telefone   String?
  whatsapp   String?
  linkedin   String?
  decisor    Boolean  @default(false)
  ativo      Boolean  @default(true)
  criado_em  DateTime @default(now())

  @@map("crm_contatos")
  @@schema("overfloow")
